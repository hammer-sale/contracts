# Copy to `.env` and fill in. `.env` is gitignored.
# Foundry reads variables interpolated as ${NAME} in foundry.toml.

# ── Arbitrum RPCs ────────────────────────────────────────────────────────────
# Public endpoints work for read-only calls, but you'll want a dedicated provider
# (Alchemy, Infura, QuickNode) for any sustained sending traffic.
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARB_ONE_RPC=https://arb1.arbitrum.io/rpc

# ── Block explorer (verification) ────────────────────────────────────────────
# Etherscan V2: a single API key works for Arbiscan, Etherscan, BscScan, etc.
# Get one at https://etherscan.io/myapikey.
ETHERSCAN_API_KEY=

# ── Deployer ─────────────────────────────────────────────────────────────────
# NEVER commit a real key. Prefer `cast wallet import` + `--account NAME` over
# raw private keys; only use this for local Anvil chains.
DEPLOYER_PRIVATE_KEY=
